# Voice layer: ElevenLabs (TTS) + Sarvam Saarika (STT, Indic-tuned). Brain stays
# on OpenAI chat models below.
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_BASE_URL=https://api.elevenlabs.io
ELEVENLABS_TTS_MODEL=eleven_v3
ELEVENLABS_SUPPORTED_LANGUAGE_CODES=en,hi,ta,mr,bn,te,gu,kn,ml,pa,or
# Per-persona ElevenLabs voice ids (female/male defaults). Replace placeholders
# with real voice ids from your ElevenLabs voice library before a live call.
ELEVENLABS_DEFAULT_FEMALE=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_DEFAULT_MALE=TxGEqnHWrfWFTfGW9XjX
ELEVENLABS_TTS_SAMPLE_RATE_BROWSER=24000
ELEVENLABS_TTS_SAMPLE_RATE_PHONE=8000
ELEVENLABS_VOICE_STABILITY=0.5
ELEVENLABS_VOICE_SIMILARITY=0.75
ELEVENLABS_VOICE_STYLE=0.0
ELEVENLABS_VOICE_SPEED=1.15
ELEVENLABS_VOICE_SPEAKER_BOOST=1
ELEVENLABS_TEXT_NORMALIZATION=on
# Pronunciation dictionary (alias rules: DHL->"D H L", NEFT spelled, etc.).
# Create via POST /v1/pronunciation-dictionaries/add-from-rules; set id+version.
ELEVENLABS_PRON_DICT_ID=
ELEVENLABS_PRON_DICT_VERSION_ID=
# eleven_v3 delivery tone (audio tags). 0 disables.
ELEVENLABS_AUDIO_TAGS=1
ELEVENLABS_TONE_DEFAULT=professional
ELEVENLABS_TONE_EMPATHETIC=empathetic
ELEVENLABS_TONE_FIRM=firm
ELEVENLABS_USD_PER_MILLION_CHARS=50
TTS_HUMANIZE=1
SARVAM_API_KEY=your_sarvam_api_key
SARVAM_BASE_URL=https://api.sarvam.ai
SARVAM_STT_MODEL=saaras:v3
SARVAM_STT_WS_URL=wss://api.sarvam.ai/speech-to-text/ws
SARVAM_STT_SAMPLE_RATE=16000
SARVAM_STT_MODE=codemix
SARVAM_INR_PER_USD=96.13
SARVAM_STT_INR_PER_HOUR=30
EXOTEL_ACCOUNT_SID=
EXOTEL_API_KEY=
EXOTEL_API_TOKEN=
EXOTEL_API_BASE_URL=https://api.in.exotel.com
EXOTEL_CALLER_ID=
EXOTEL_STREAM_SAMPLE_RATE=8000

OPENAI_API_KEY=your_openai_api_key
OPENAI_SUPERVISOR_MODEL=gpt-4.1-mini
OPENAI_LANGUAGE_COACH_MODEL=gpt-4.1-mini
OPENAI_CHAT_MODEL=gpt-4.1
POLICY_ENGINE_MODE=llm
DEMO_ACCOUNT_ID=DHL001

# Optional: override the backend price table used for estimated cost callouts.
# MODEL_PRICE_TABLE_JSON={"gpt-realtime":{"text_input_per_million":4.0}}
